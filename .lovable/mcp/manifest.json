{
  "version": 1,
  "sdk_version": "0.23.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://unmdpiavvvjaipnvhnum.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "erdman-alumni-mcp",
      "version": "0.1.0",
      "title": "Erdman Alumni MCP"
    },
    "tools": [
      {
        "name": "search_alumni",
        "title": "Search alumni directory",
        "description": "Search the alumni directory by name, company, specialization, graduation year, location, or candidate type. Returns non-sensitive public profile fields.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Free-text match against name, company, job title, or bio."
            },
            "graduation_year": {
              "type": "integer"
            },
            "specialization": {
              "type": "string"
            },
            "location": {
              "type": "string"
            },
            "candidate_type": {
              "type": "string",
              "enum": [
                "Domestic",
                "International"
              ]
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "description": "Max rows to return (default 20)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_my_profile",
        "title": "Get my alumni profile",
        "description": "Return the signed-in alumni's own profile (including private fields).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_upcoming_events",
        "title": "List upcoming events",
        "description": "List approved upcoming alumni events.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_referrals",
        "title": "List job referrals",
        "description": "List approved, active job referral offers and requests posted by alumni.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "referral_type": {
              "type": "string",
              "enum": [
                "offering",
                "requesting"
              ]
            },
            "company": {
              "type": "string"
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_groups",
        "title": "List alumni groups",
        "description": "List approved alumni groups and communities.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Free-text match against name or description."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "create_community_post",
        "title": "Create a community post",
        "description": "Create a new post in the community feed as the signed-in alumni. Optionally scope to a group the user belongs to.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "content": {
              "type": "string",
              "minLength": 1,
              "maxLength": 4000
            },
            "group_id": {
              "type": "string",
              "format": "uuid",
              "description": "Group to scope the post to (must be a member)."
            }
          },
          "required": [
            "content"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
